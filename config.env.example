# Example configuration for claude-local.
# Copy to ~/.config/claude-local/config.env and edit.
# Or run: claude-local config <endpoint> <model>

# vLLM server endpoint (no trailing slash, no /v1 suffix)
ANTHROPIC_BASE_URL=http://localhost:8000

# Auth (vLLM doesn't need a real key, but Claude Code requires one to be set)
ANTHROPIC_API_KEY=local

# Model name as registered in vLLM (--served-model-name)
ANTHROPIC_DEFAULT_OPUS_MODEL=qwen3-8b
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3-8b
ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen3-8b

# Disable experimental betas that may not work with local models
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
